# ========================================
# 项目构建产物与依赖 (Build Output & Dependencies)
# ========================================
# 后端 Maven 构建产物
backend/target/
backend/*.class
backend/*.jar
backend/*.war
backend/*.ear
backend/*.nar

# 前端 Node.js 依赖
frontend/node_modules/
# Vite 编译产物
frontend/dist/
frontend/dist-ssr/
# Vue CLI 相关产物（如果使用）
frontend/build/
frontend/*.js
frontend/*.map
frontend/*.chunk.*

# ========================================
# 本地环境与敏感配置 (Local Config & Secrets)
# ========================================
# 本地环境变量文件（包含敏感配置）
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.local

# IDE 本地配置
backend/.idea/
frontend/.idea/
.idea/
*.iml
*.iws
*.ipr

# VS Code 本地缓存
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ========================================
# 运行时与临时文件 (Runtime & Temporary Files)
# ========================================
# 日志文件
*.log
*.log.*
logs/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# 系统临时文件
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ========================================
# 项目特定忽略 (Project Specific)
# ========================================
# Maven 包装器
backend/.mvn/wrapper/maven-wrapper.jar

# 数据库变更增量脚本（只在特定版本使用，避免误扫描）
doc/sql/changelog/v*.sql

# 编译缓存
*.class
*.swp
*.swo
*~

# ========================================
# Claude 相关 (Claude Code Specific)
# ========================================
.claude/
!/.claude/settings.json
!/.claude/CLAUDE.md

# 临时任务文件
.task/
*.task
